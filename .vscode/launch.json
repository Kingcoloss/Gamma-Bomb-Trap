{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "python": "${workspaceFolder}/.virtenv/bin/python",
      "name": "Streamlit: streamlit_app",
      "type": "debugpy",
      "request": "launch",
      "program": "-m",
      //"module": "streamlit",
      "args": [
        "streamlit",
        "run",
        "streamlit_app.py",
        "--server.enableCORS",
        "false",
        "--server.enableXsrfProtection",
        "false"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "cwd": "${workspaceFolder}"
    }
  ]
}